---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout title="Contact — Français">
  <h1>Contact - Français</h1>

  <form method="post">
    <label>
      Nom
      <input name="name" />
    </label>
    <br />
    <label>
      Email
      <input name="email" type="email" />
    </label>
    <br />
    <label>
      Message
      <textarea name="message"></textarea>
    </label>
    <br />
    <button type="submit">Envoyer</button>
  </form>
</BaseLayout>
