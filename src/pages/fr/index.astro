---
import BaseLayout from "@/layouts/BaseLayout.astro";

const blocs = [
  {
    title: "Eau",
    desc: "Traitement, réutilisation et gestion durable de l’eau.",
    href: "/fr/environnement/eau/",
    img: "/images/home-eau.jpg",
    alt: "Solutions de traitement et gestion de l’eau",
  },
  {
    title: "Déchets",
    desc: "Gestion et valorisation des matières résiduelles.",
    href: "/fr/environnement/dechets/",
    img: "/images/home-dechets.jpg",
    alt: "Solutions de gestion des déchets",
  },
  {
    title: "Énergie",
    desc: "Solaire et stockage d’énergie.",
    href: "/fr/energie/",
    img: "/images/home-energie.jpg",
    alt: "Solutions d’énergie durable",
  },
];
---

<BaseLayout title="TCE-enviro | Accueil">

  <!-- HERO -->
  <section class="hero">
    <img
      src="/images/hero-home.jpg"
      alt="Solutions environnementales TCE-enviro"
    />
  </section>

  <!-- BLOCS -->
  <section class="home-blocks">
    <div class="blocks-grid">
      {blocs.map((b) => (
        <a class="block-card" href={b.href}>
          <div class="block-media">
            <img src={b.img} alt={b.alt} loading="lazy" />
          </div>

          <div class="block-body">
            <h2>{b.title}</h2>
            <p>{b.desc}</p>
            <span class="block-cta">Découvrir →</span>
          </div>
        </a>
      ))}
    </div>
  </section>

</BaseLayout>

<style>

.hero img{
  width:100%;
  height:60vh;
  max-height:520px;
  object-fit:cover;
  display:block;
}

.home-blocks{
  padding:3rem 2rem;
  max-width:1200px;
  margin:auto;
}

.blocks-grid{
  display:grid;
  gap:1.5rem;
  grid-template-columns:1fr;
}

@media (min-width:900px){
  .blocks-grid{
    grid-template-columns:repeat(3,1fr);
  }
}

.block-card{
  display:block;
  text-decoration:none;
  color:inherit;
  border-radius:14px;
  overflow:hidden;
  border:1px solid rgba(0,0,0,.08);
  background:#fff;
  box-shadow:0 10px 30px rgba(0,0,0,.06);
  transition:transform .18s ease, box-shadow .18s ease;
}

.block-card:hover{
  transform:translateY(-4px);
  box-shadow:0 16px 36px rgba(0,0,0,.12);
}

.block-media{
  aspect-ratio:16/9;
}

.block-media img{
  width:100%;
  height:100%;
  object-fit:cover;
}

.block-body{
  padding:1.2rem;
}

.block-body h2{
  margin:0 0 .4rem 0;
  font-size:1.3rem;
}

.block-body p{
  margin:0 0 .8rem 0;
  color:#555;
}

.block-cta{
  font-weight:600;
}

</style>